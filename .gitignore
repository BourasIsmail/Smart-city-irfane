# =============================================================================
#  FIWARE Smart City Digital Twin — Irfane, Rabat
#  Root .gitignore — covers the entire project
#  Place this file at: smart-city-irfane/.gitignore
# =============================================================================

# ── Environment variables — NEVER commit ─────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env.local

# ── Node.js dependencies ──────────────────────────────────────────────
node_modules/
frontend/node_modules/
simulators/node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Next.js build output ──────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/build/
frontend/dist/

# ── TypeScript ────────────────────────────────────────────────────────
*.tsbuildinfo
frontend/next-env.d.ts

# ── Logs ──────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Docker ────────────────────────────────────────────────────────────
# Keep docker-compose.yml but ignore any local override
docker-compose.override.yml

# ── OS files ──────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Editor & IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── Testing & coverage ───────────────────────────────────────────────
coverage/
.nyc_output/
frontend/coverage/

# ── Misc ──────────────────────────────────────────────────────────────
*.pem
.vercel
.turbo